	--file docker/benchmark-runner/Dockerfile \
	.

run-aflsmart_plusplus-binutils-fuzz_cxxfilt: .aflsmart_plusplus-binutils-fuzz_cxxfilt-runner
	docker run \
	--cpus=1 \
	--shm-size=2g \
	--cap-add SYS_NICE \
	--cap-add SYS_PTRACE \
	-e FUZZ_OUTSIDE_EXPERIMENT=1 \
	-e FORCE_LOCAL=1 \
	-e TRIAL_ID=1 \
	-e FUZZER=aflsmart_plusplus \
	-e BENCHMARK=binutils-fuzz_cxxfilt \
	-e FUZZ_TARGET=$(binutils-fuzz_cxxfilt-fuzz-target) \
	-it gcr.io/fuzzbench/runners/aflsmart_plusplus/binutils-fuzz_cxxfilt

